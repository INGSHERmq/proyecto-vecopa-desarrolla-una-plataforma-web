{
  "version": 2,
  "name": "vecopa",
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install",
  "functions": {
    "apps/api/vercel-entrypoint.js": {
      "runtime": "nodejs20.x",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "apps/api/vercel-entrypoint.js"
    }
  ]
}