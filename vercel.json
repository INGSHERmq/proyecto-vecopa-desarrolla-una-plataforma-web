{
  "version": 2,
  "name": "vecopa",
  "functions": {
    "apps/api/src/main.ts": {
      "runtime": "nodejs20.x",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "apps/api/src/main.ts"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install"
}